# Set ENV to "dev" or "prod" to switch Supabase targets
ENV=dev

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Dev Supabase
DEV_SUPABASE_DB_HOST=aws-1-us-east-1.pooler.supabase.com
DEV_SUPABASE_DB_USER=postgres.your-dev-project-id
DEV_SUPABASE_DB_PORT=6543
DEV_SUPABASE_DB_PASSWORD=your-dev-postgres-password
DEV_SUPABASE_URL=https://your-dev-project-id.supabase.co
DEV_SUPABASE_SECRET_KEY=your-dev-service-role-key

# Prod Supabase
SUPABASE_DB_HOST=aws-1-us-east-1.pooler.supabase.com
SUPABASE_DB_USER=postgres.your-prod-project-id
SUPABASE_DB_PORT=6543
SUPABASE_DB_PASSWORD=your-prod-postgres-password
SUPABASE_URL=https://your-prod-project-id.supabase.co
SUPABASE_SECRET_KEY=your-prod-service-role-key
